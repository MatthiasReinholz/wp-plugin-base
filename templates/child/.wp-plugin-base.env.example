FOUNDATION_RELEASE_SOURCE_PROVIDER=github-release
FOUNDATION_RELEASE_SOURCE_REFERENCE=MatthiasReinholz/wp-plugin-base
# FOUNDATION_RELEASE_SOURCE_API_BASE=https://api.github.com
# FOUNDATION_RELEASE_SOURCE_SIGSTORE_ISSUER=https://token.actions.githubusercontent.com
FOUNDATION_VERSION=v1.7.10
# AUTOMATION_PROVIDER=github
# AUTOMATION_API_BASE=https://api.github.com
# TRUSTED_GIT_HOSTS=gitlab.example.com,auth.gitlab.example.com
PLUGIN_NAME="Example Plugin"
PLUGIN_SLUG=example-plugin
MAIN_PLUGIN_FILE=example-plugin.php
README_FILE=readme.txt
ZIP_FILE=example-plugin.zip
PHP_VERSION=8.1
NODE_VERSION=20
# PLUGIN_RUNTIME_UPDATE_PROVIDER=none
# PLUGIN_RUNTIME_UPDATE_SOURCE_URL=

# Optional values:
# PRODUCTION_ENVIRONMENT=production  # defaults to production when unset
# PHP_RUNTIME_MATRIX=8.1,8.2,8.3
# PHP_RUNTIME_MATRIX_MODE=strict
# VERSION_CONSTANT_NAME=EXAMPLE_PLUGIN_VERSION
# POT_FILE=languages/example-plugin.pot
# POT_PROJECT_NAME="Example Plugin"
# WORDPRESS_ORG_SLUG=example-plugin
# WORDPRESS_READINESS_ENABLED=true
# WORDPRESS_QUALITY_PACK_ENABLED=true  # requires WORDPRESS_READINESS_ENABLED=true
# WORDPRESS_SECURITY_PACK_ENABLED=true  # requires WORDPRESS_READINESS_ENABLED=true
# RELEASE_READINESS_MODE=security-sensitive
# WOOCOMMERCE_QIT_ENABLED=true
# WOOCOMMERCE_COM_PRODUCT_ID=12345
# WOOCOMMERCE_COM_ENDPOINT_TIMEOUT_SECONDS=30
# FOUNDATION_REPOSITORY=owner/repo  # legacy GitHub alias for FOUNDATION_RELEASE_SOURCE_REFERENCE
# AUTOMATION_API_BASE=https://gitlab.example.com/api/v4
# For GitLab-hosted foundations, switch the provider to gitlab-release and set the reference to group/project.
# FOUNDATION_RELEASE_SOURCE_API_BASE=https://gitlab.example.com/api/v4
# FOUNDATION_RELEASE_SOURCE_SIGSTORE_ISSUER=https://auth.gitlab.example.com  # required for self-managed GitLab foundation sources
# PLUGIN_RUNTIME_UPDATE_PROVIDER=github-release
# PLUGIN_RUNTIME_UPDATE_SOURCE_URL=https://github.com/owner/repo
# PLUGIN_RUNTIME_UPDATE_PROVIDER=gitlab-release
# PLUGIN_RUNTIME_UPDATE_SOURCE_URL=https://gitlab.com/group/project  # requires AUTOMATION_PROVIDER=gitlab
# PLUGIN_RUNTIME_UPDATE_PROVIDER=generic-json
# PLUGIN_RUNTIME_UPDATE_SOURCE_URL=https://downloads.example.com/plugin-update.json
# GITHUB_RELEASE_UPDATER_ENABLED=true
# GITHUB_RELEASE_UPDATER_REPO_URL=https://github.com/owner/repo  # legacy alias for GitHub runtime updater
# REST_OPERATIONS_PACK_ENABLED=true
# REST_API_NAMESPACE=example-plugin/v1
# REST_ABILITIES_ENABLED=false
# ADMIN_UI_PACK_ENABLED=true
# ADMIN_UI_STARTER=basic
# ADMIN_UI_EXPERIMENTAL_DATAVIEWS=false
# ADMIN_UI_NPM_AUDIT_LEVEL=high
# WP_PLUGIN_BASE_PLUGIN_CHECK_CHECKS=plugin_header_fields,plugin_readme
# WP_PLUGIN_BASE_PLUGIN_CHECK_EXCLUDE_CHECKS=prefixing
# WP_PLUGIN_BASE_PLUGIN_CHECK_CATEGORIES=plugin_repo,security
# WP_PLUGIN_BASE_PLUGIN_CHECK_IGNORE_CODES=readme_parser_warnings_trailing_whitespace
# WP_PLUGIN_BASE_PLUGIN_CHECK_STRICT_WARNINGS=true
# WP_PLUGIN_BASE_PLUGIN_CHECK_SEVERITY=6
# WP_PLUGIN_BASE_PLUGIN_CHECK_ERROR_SEVERITY=7
# WP_PLUGIN_BASE_PLUGIN_CHECK_WARNING_SEVERITY=7
# EXTRA_ALLOWED_HOSTS=raw.githubusercontent.com
# WP_PLUGIN_BASE_SECURITY_SUPPRESSIONS_FILE=.wp-plugin-base-security-suppressions.json
# DISTIGNORE_FILE=.distignore
# PACKAGE_INCLUDE=admin,includes,public,example-plugin.php,readme.txt,LICENSE
# PACKAGE_EXCLUDE=tests
# BUILD_SCRIPT=.wp-plugin-base-admin-ui/build.sh
# BUILD_SCRIPT_ARGS=--production,--minify
# PHPDOC_VERSION_REPLACEMENT_ENABLED=true
# PHPDOC_VERSION_PLACEHOLDER=NEXT
# CHANGELOG_MD_SYNC_ENABLED=true
# CHANGELOG_SOURCE=change_request_titles
# SIMULATE_RELEASE_WORKFLOW_ENABLED=true
# GLOTPRESS_TRIGGER_ENABLED=true
# GLOTPRESS_URL=https://translate.example.com
# GLOTPRESS_PROJECT_SLUG=my-plugin
# GLOTPRESS_FAIL_ON_ERROR=false
# DEPLOY_NOTIFICATION_ENABLED=true
# CHANGELOG_HEADING=Changelog
# CODEOWNERS_REVIEWERS="@your-org/team @your-user"
