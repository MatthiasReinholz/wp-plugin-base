root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.{md,txt}]
indent_style = unset
indent_size = unset
trim_trailing_whitespace = false

[*.php]
indent_style = unset
indent_size = unset

[*.php.example]
indent_style = tab
indent_size = 4

[*.sh]
indent_size = 2

[Makefile]
indent_style = tab

[LICENSE]
indent_style = unset
indent_size = unset
