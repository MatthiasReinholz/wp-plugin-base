{
  "schema_version": 1,
  "scopes": [
    "sync",
    "foundation",
    "project",
    "ci",
    "readiness",
    "release",
    "deploy-structure",
    "deploy"
  ],
  "keys": {
    "FOUNDATION_REPOSITORY": {
      "required_in_scopes": ["sync", "foundation", "project", "ci", "readiness", "release", "deploy-structure", "deploy"],
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    },
    "FOUNDATION_VERSION": {
      "required_in_scopes": ["sync", "foundation", "project", "ci", "readiness", "release", "deploy-structure", "deploy"],
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "PLUGIN_NAME": {
      "required_in_scopes": ["project", "ci", "readiness", "release", "deploy-structure", "deploy"]
    },
    "PLUGIN_SLUG": {
      "required_in_scopes": ["project", "ci", "readiness", "release", "deploy-structure", "deploy"],
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "MAIN_PLUGIN_FILE": {
      "required_in_scopes": ["project", "ci", "readiness", "release", "deploy-structure", "deploy"]
    },
    "README_FILE": {
      "required_in_scopes": ["project", "ci", "readiness", "release", "deploy-structure", "deploy"]
    },
    "ZIP_FILE": {
      "required_in_scopes": ["project", "ci", "readiness", "release", "deploy-structure", "deploy"],
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*\\.zip$"
    },
    "PHP_VERSION": {
      "required_in_scopes": ["project", "ci", "readiness", "release", "deploy-structure", "deploy"],
      "pattern": "^[0-9]+(\\.[0-9]+){0,2}$"
    },
    "NODE_VERSION": {
      "required_in_scopes": ["project", "ci", "readiness", "release", "deploy-structure", "deploy"],
      "pattern": "^[0-9]+(\\.[0-9]+){0,2}$"
    },
    "PRODUCTION_ENVIRONMENT": {
      "default": "production",
      "pattern": "^[A-Za-z0-9_.-]+$"
    },
    "PHP_RUNTIME_MATRIX": {
      "default": "",
      "pattern": "^$|^[0-9]+(\\.[0-9]+){0,2}(,[0-9]+(\\.[0-9]+){0,2})*$"
    },
    "PHP_RUNTIME_MATRIX_MODE": {
      "default": "smoke",
      "pattern": "^(smoke|strict)$"
    },
    "VERSION_CONSTANT_NAME": {
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "POT_FILE": {},
    "POT_PROJECT_NAME": {},
    "WORDPRESS_ORG_SLUG": {
      "required_in_scopes": ["deploy-structure", "deploy"],
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "WORDPRESS_READINESS_ENABLED": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "WORDPRESS_QUALITY_PACK_ENABLED": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "WORDPRESS_SECURITY_PACK_ENABLED": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "WOOCOMMERCE_QIT_ENABLED": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "WOOCOMMERCE_COM_PRODUCT_ID": {
      "default": "",
      "pattern": "^$|^[0-9]+$"
    },
    "WOOCOMMERCE_COM_ENDPOINT_TIMEOUT_SECONDS": {
      "default": "30",
      "pattern": "^[1-9][0-9]*$"
    },
    "GITHUB_RELEASE_UPDATER_ENABLED": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "GITHUB_RELEASE_UPDATER_REPO_URL": {
      "default": "",
      "pattern": "^$|^https://github[.]com/[^/]+/[^/]+/?$"
    },
    "REST_OPERATIONS_PACK_ENABLED": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "REST_API_NAMESPACE": {
      "default": "",
      "pattern": "^$|^[a-z0-9][a-z0-9-]*/v[0-9]+$"
    },
    "REST_ABILITIES_ENABLED": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "ADMIN_UI_PACK_ENABLED": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "ADMIN_UI_STARTER": {
      "default": "",
      "pattern": "^$|^(basic|dataviews)$"
    },
    "ADMIN_UI_EXPERIMENTAL_DATAVIEWS": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "WP_PLUGIN_BASE_PLUGIN_CHECK_CHECKS": {
      "default": "",
      "pattern": "^$|^[A-Za-z0-9_.-]+(,[A-Za-z0-9_.-]+)*$"
    },
    "WP_PLUGIN_BASE_PLUGIN_CHECK_EXCLUDE_CHECKS": {
      "default": "",
      "pattern": "^$|^[A-Za-z0-9_.-]+(,[A-Za-z0-9_.-]+)*$"
    },
    "WP_PLUGIN_BASE_PLUGIN_CHECK_CATEGORIES": {
      "default": "",
      "pattern": "^$|^[A-Za-z0-9_.-]+(,[A-Za-z0-9_.-]+)*$"
    },
    "WP_PLUGIN_BASE_PLUGIN_CHECK_IGNORE_CODES": {
      "default": "",
      "pattern": "^$|^[A-Za-z0-9_.-]+(,[A-Za-z0-9_.-]+)*$"
    },
    "WP_PLUGIN_BASE_PLUGIN_CHECK_STRICT_WARNINGS": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "WP_PLUGIN_BASE_PLUGIN_CHECK_SEVERITY": {
      "default": "",
      "pattern": "^$|^[0-9]+$"
    },
    "WP_PLUGIN_BASE_PLUGIN_CHECK_ERROR_SEVERITY": {
      "default": "",
      "pattern": "^$|^[0-9]+$"
    },
    "WP_PLUGIN_BASE_PLUGIN_CHECK_WARNING_SEVERITY": {
      "default": "",
      "pattern": "^$|^[0-9]+$"
    },
    "EXTRA_ALLOWED_HOSTS": {
      "default": "",
      "pattern": "^[A-Za-z0-9.-]+$",
      "csv": true
    },
    "WP_PLUGIN_BASE_SECURITY_SUPPRESSIONS_FILE": {
      "default": ".wp-plugin-base-security-suppressions.json"
    },
    "PACKAGE_INCLUDE": {
      "default": "",
      "csv": true
    },
    "PACKAGE_EXCLUDE": {
      "default": "",
      "csv": true
    },
    "CHANGELOG_HEADING": {
      "default": "Changelog"
    },
    "CODEOWNERS_REVIEWERS": {
      "default": ""
    },
    "DISTIGNORE_FILE": {
      "default": ".distignore"
    },
    "BUILD_SCRIPT": {
      "default": ""
    },
    "BUILD_SCRIPT_ARGS": {
      "default": "",
      "csv": true
    },
    "PHPDOC_VERSION_REPLACEMENT_ENABLED": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "PHPDOC_VERSION_PLACEHOLDER": {
      "default": "NEXT"
    },
    "CHANGELOG_MD_SYNC_ENABLED": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "CHANGELOG_SOURCE": {
      "default": "commits",
      "pattern": "^(commits|prs_titles)$"
    },
    "SIMULATE_RELEASE_WORKFLOW_ENABLED": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "GLOTPRESS_TRIGGER_ENABLED": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "GLOTPRESS_URL": {
      "default": "",
      "pattern": "^$|^https://[^[:space:]]+$"
    },
    "GLOTPRESS_PROJECT_SLUG": {
      "default": ""
    },
    "GLOTPRESS_FAIL_ON_ERROR": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "DEPLOY_NOTIFICATION_ENABLED": {
      "default": "false",
      "pattern": "^(true|false)$"
    }
  }
}
