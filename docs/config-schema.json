{
  "schema_version": 1,
  "scopes": [
    "sync",
    "foundation",
    "project",
    "ci",
    "readiness",
    "release",
    "deploy-structure",
    "deploy"
  ],
  "keys": {
    "FOUNDATION_REPOSITORY": {
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    },
    "FOUNDATION_RELEASE_SOURCE_PROVIDER": {
      "description": "Authoritative upstream wp-plugin-base release provider. This may differ from the downstream repository host during planned migrations.",
      "required_in_scopes": ["sync", "foundation", "project", "ci", "readiness", "release", "deploy-structure", "deploy"],
      "default": "github-release",
      "pattern": "^(github-release|gitlab-release)$"
    },
    "FOUNDATION_RELEASE_SOURCE_REFERENCE": {
      "description": "Provider-specific authoritative upstream release reference. Use the neutral FOUNDATION_RELEASE_SOURCE_* keys for new configuration; FOUNDATION_REPOSITORY remains a GitHub compatibility alias.",
      "required_in_scopes": ["sync", "foundation", "project", "ci", "readiness", "release", "deploy-structure", "deploy"],
      "pattern": "^[A-Za-z0-9_.-]+(?:/[A-Za-z0-9_.-]+)+$"
    },
    "FOUNDATION_RELEASE_SOURCE_API_BASE": {
      "description": "Optional API base for the authoritative upstream release provider. Runtime validation only trusts default GitHub/GitLab hosts unless TRUSTED_GIT_HOSTS explicitly allowlists a self-managed host.",
      "default": "https://api.github.com",
      "pattern": "^$|^https://[^[:space:]]+$"
    },
    "FOUNDATION_RELEASE_SOURCE_SIGSTORE_ISSUER": {
      "description": "Optional explicit Sigstore/OIDC issuer override for authoritative upstream release verification. Required for self-managed GitLab foundation sources because issuer URLs are instance-specific.",
      "default": "",
      "pattern": "^$|^https://[^[:space:]]+$"
    },
    "FOUNDATION_VERSION": {
      "required_in_scopes": ["sync", "foundation", "project", "ci", "readiness", "release", "deploy-structure", "deploy"],
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "AUTOMATION_PROVIDER": {
      "description": "Canonical downstream repository host selector. A downstream project uses one automation host profile at a time in this release.",
      "default": "github",
      "pattern": "^(github|gitlab)$"
    },
    "AUTOMATION_API_BASE": {
      "description": "Optional API base for the downstream automation host. Runtime validation only trusts default GitHub/GitLab hosts unless TRUSTED_GIT_HOSTS explicitly allowlists a self-managed host.",
      "default": "https://api.github.com",
      "pattern": "^$|^https://[^[:space:]]+$"
    },
    "TRUSTED_GIT_HOSTS": {
      "description": "Comma-separated allowlist for self-managed GitHub Enterprise or GitLab hosts that are permitted as API or runtime-update endpoints. Localhost, private-network, link-local, and *.internal hosts are rejected.",
      "default": "",
      "pattern": "^[A-Za-z0-9.-]+$",
      "csv": true
    },
    "PLUGIN_RUNTIME_UPDATE_PROVIDER": {
      "description": "Optional runtime updater provider. Host-backed providers follow the downstream single-host contract: github-release requires AUTOMATION_PROVIDER=github and gitlab-release requires AUTOMATION_PROVIDER=gitlab.",
      "default": "none",
      "pattern": "^(none|github-release|gitlab-release|generic-json)$"
    },
    "PLUGIN_RUNTIME_UPDATE_SOURCE_URL": {
      "description": "Runtime updater source URL. Host-backed providers must point at trusted GitHub/GitLab hosts or allowlisted self-managed hosts. All runtime update URLs must be public HTTPS URLs without credentials, query strings, fragments, localhost/private-network hosts, or embedded secrets because the URL ships in the plugin payload.",
      "default": "",
      "pattern": "^$|^https://[^[:space:]]+$"
    },
    "PLUGIN_NAME": {
      "required_in_scopes": ["project", "ci", "readiness", "release", "deploy-structure", "deploy"]
    },
    "PLUGIN_SLUG": {
      "required_in_scopes": ["project", "ci", "readiness", "release", "deploy-structure", "deploy"],
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "MAIN_PLUGIN_FILE": {
      "required_in_scopes": ["project", "ci", "readiness", "release", "deploy-structure", "deploy"]
    },
    "README_FILE": {
      "required_in_scopes": ["project", "ci", "readiness", "release", "deploy-structure", "deploy"]
    },
    "ZIP_FILE": {
      "required_in_scopes": ["project", "ci", "readiness", "release", "deploy-structure", "deploy"],
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*\\.zip$"
    },
    "PHP_VERSION": {
      "required_in_scopes": ["project", "ci", "readiness", "release", "deploy-structure", "deploy"],
      "pattern": "^[0-9]+(\\.[0-9]+){0,2}$"
    },
    "NODE_VERSION": {
      "required_in_scopes": ["project", "ci", "readiness", "release", "deploy-structure", "deploy"],
      "pattern": "^[0-9]+(\\.[0-9]+){0,2}$"
    },
    "PRODUCTION_ENVIRONMENT": {
      "default": "production",
      "pattern": "^[A-Za-z0-9_.-]+$"
    },
    "PHP_RUNTIME_MATRIX": {
      "default": "",
      "pattern": "^$|^[0-9]+(\\.[0-9]+){0,2}(,[0-9]+(\\.[0-9]+){0,2})*$"
    },
    "PHP_RUNTIME_MATRIX_MODE": {
      "default": "smoke",
      "pattern": "^(smoke|strict)$"
    },
    "VERSION_CONSTANT_NAME": {
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "POT_FILE": {},
    "POT_PROJECT_NAME": {},
    "WORDPRESS_ORG_SLUG": {
      "required_in_scopes": ["deploy-structure", "deploy"],
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "WORDPRESS_READINESS_ENABLED": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "WORDPRESS_QUALITY_PACK_ENABLED": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "WORDPRESS_SECURITY_PACK_ENABLED": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "RELEASE_READINESS_MODE": {
      "description": "Optional fail-closed readiness profile. Use security-sensitive for plugins that must not release with reduced WordPress readiness, quality, security, Plugin Check, or audit coverage.",
      "default": "standard",
      "pattern": "^(standard|security-sensitive)$"
    },
    "WOOCOMMERCE_QIT_ENABLED": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "WOOCOMMERCE_COM_PRODUCT_ID": {
      "default": "",
      "pattern": "^$|^[0-9]+$"
    },
    "WOOCOMMERCE_COM_ENDPOINT_TIMEOUT_SECONDS": {
      "default": "30",
      "pattern": "^[1-9][0-9]*$"
    },
    "GITHUB_RELEASE_UPDATER_ENABLED": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "GITHUB_RELEASE_UPDATER_REPO_URL": {
      "default": "",
      "pattern": "^$|^https://github[.]com/[^/]+/[^/]+/?$"
    },
    "REST_OPERATIONS_PACK_ENABLED": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "REST_API_NAMESPACE": {
      "default_template": "${PLUGIN_SLUG}/v1",
      "pattern": "^$|^[a-z0-9][a-z0-9-]*/v[0-9]+$"
    },
    "REST_ABILITIES_ENABLED": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "ADMIN_UI_PACK_ENABLED": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "ADMIN_UI_STARTER": {
      "default": "basic",
      "pattern": "^$|^(basic|dataviews)$"
    },
    "ADMIN_UI_EXPERIMENTAL_DATAVIEWS": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "ADMIN_UI_NPM_AUDIT_LEVEL": {
      "description": "Audit threshold used for the managed admin UI npm toolchain when the security pack is enabled. Keep high by default; critical is a temporary compatibility override for upstream-only toolchain advisories and is rejected by RELEASE_READINESS_MODE=security-sensitive.",
      "default": "high",
      "pattern": "^(high|critical)$"
    },
    "WP_PLUGIN_BASE_PLUGIN_CHECK_CHECKS": {
      "default": "",
      "pattern": "^$|^[A-Za-z0-9_.-]+(,[A-Za-z0-9_.-]+)*$"
    },
    "WP_PLUGIN_BASE_PLUGIN_CHECK_EXCLUDE_CHECKS": {
      "default": "",
      "pattern": "^$|^[A-Za-z0-9_.-]+(,[A-Za-z0-9_.-]+)*$"
    },
    "WP_PLUGIN_BASE_PLUGIN_CHECK_CATEGORIES": {
      "default": "",
      "pattern": "^$|^[A-Za-z0-9_.-]+(,[A-Za-z0-9_.-]+)*$"
    },
    "WP_PLUGIN_BASE_PLUGIN_CHECK_IGNORE_CODES": {
      "default": "",
      "pattern": "^$|^[A-Za-z0-9_.-]+(,[A-Za-z0-9_.-]+)*$"
    },
    "WP_PLUGIN_BASE_PLUGIN_CHECK_STRICT_WARNINGS": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "WP_PLUGIN_BASE_PLUGIN_CHECK_SEVERITY": {
      "default": "",
      "pattern": "^$|^[0-9]+$"
    },
    "WP_PLUGIN_BASE_PLUGIN_CHECK_ERROR_SEVERITY": {
      "default": "",
      "pattern": "^$|^[0-9]+$"
    },
    "WP_PLUGIN_BASE_PLUGIN_CHECK_WARNING_SEVERITY": {
      "default": "",
      "pattern": "^$|^[0-9]+$"
    },
    "EXTRA_ALLOWED_HOSTS": {
      "default": "",
      "pattern": "^[A-Za-z0-9.-]+$",
      "csv": true
    },
    "WP_PLUGIN_BASE_SECURITY_SUPPRESSIONS_FILE": {
      "default": ".wp-plugin-base-security-suppressions.json"
    },
    "PACKAGE_INCLUDE": {
      "default": "",
      "csv": true
    },
    "PACKAGE_EXCLUDE": {
      "default": "",
      "csv": true
    },
    "CHANGELOG_HEADING": {
      "default": "Changelog"
    },
    "CODEOWNERS_REVIEWERS": {
      "default": ""
    },
    "DISTIGNORE_FILE": {
      "default": ".distignore"
    },
    "BUILD_SCRIPT": {
      "default": ""
    },
    "BUILD_SCRIPT_ARGS": {
      "default": "",
      "csv": true
    },
    "PHPDOC_VERSION_REPLACEMENT_ENABLED": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "PHPDOC_VERSION_PLACEHOLDER": {
      "default": "NEXT"
    },
    "CHANGELOG_MD_SYNC_ENABLED": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "CHANGELOG_SOURCE": {
      "default": "commits",
      "pattern": "^(commits|prs_titles|change_request_titles)$"
    },
    "SIMULATE_RELEASE_WORKFLOW_ENABLED": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "GLOTPRESS_TRIGGER_ENABLED": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "GLOTPRESS_URL": {
      "default": "",
      "pattern": "^$|^https://[^[:space:]]+$"
    },
    "GLOTPRESS_PROJECT_SLUG": {
      "default": ""
    },
    "GLOTPRESS_FAIL_ON_ERROR": {
      "default": "false",
      "pattern": "^(true|false)$"
    },
    "DEPLOY_NOTIFICATION_ENABLED": {
      "default": "false",
      "pattern": "^(true|false)$"
    }
  }
}
